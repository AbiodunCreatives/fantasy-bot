
# Telegram
DASHBOARD_ONLY_MODE=false
BOT_TOKEN=
WEBHOOK_URL=
WEBHOOK_PATH_SECRET=
WEBHOOK_SECRET=
HEALTH_CHECK_TOKEN=
ADMIN_DASHBOARD_TOKEN=
ADMIN_USER_ID=
PAJCASH_ENV=production
PAJCASH_API_KEY=
PAJCASH_SESSION_RECIPIENT=
PAJCASH_SESSION_TOKEN=
PAJCASH_SESSION_EXPIRES_AT=
PAJCASH_WEBHOOK_BASE_URL=
PAJCASH_WEBHOOK_PATH_SECRET=
PAJCASH_OTP=
PAJCASH_BUSINESS_USDC_FEE=
PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis
REDIS_MODE=redis
REDIS_URL=
# For simple single-instance testing, set REDIS_MODE=memory and leave REDIS_URL blank.
VIRTUAL_WALLET_START_BALANCE=0

# Solana USDC wallet
SOLANA_RPC_URL=https://your-solana-rpc.example
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Base64-encoded 64-byte Solana secret key for the treasury/hot wallet.
SOLANA_TREASURY_SECRET_KEY=your-base64-or-json-secret-key
# 32-byte key in hex or base64 used to encrypt per-user custodial wallet keys.
SOLANA_WALLET_ENCRYPTION_KEY=your-32-byte-hex-or-base64-key
SOLANA_WALLET_MONITOR_INTERVAL_MS=60000
SOLANA_WITHDRAW_MIN_AMOUNT=1

# Fantasy schedulers
FANTASY_MONITOR_INTERVAL_MS=60000
FANTASY_SETTLEMENT_INTERVAL_MS=60000

# Dextopus cross-chain deposit
# Your EVM wallet address to collect partner fees on every cross-chain deposit
DEXTOPUS_PARTNER_FEE_RECIPIENT=
# Fee in basis points (e.g. 30 = 0.30%). Set to 0 to disable.
DEXTOPUS_PARTNER_FEE_BPS=30

# Environment
NODE_ENV=development

# Dev overrides (comma-separated Telegram IDs)
# These users pay $0.20 entry but get a $1000 virtual bankroll for realistic screenshots.
DEV_OVERRIDE_TG_IDS=
